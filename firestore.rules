rules_version = '2';

// BulGetir — Erişim Kodu Güvenlik Kuralları
// Bu kuralları Firebase Console → Firestore → Rules sekmesine yapıştırın.
//
// İlk kurulum sırasında (seed işlemi için) geçici olarak aşağıdaki
// yazma kuralını kullanın:
//   allow write: if request.auth != null;
// Seed tamamlandıktan sonra tekrar:
//   allow write: if false;
// olarak güncelleyin.

service cloud.firestore {
  match /databases/{database}/documents {

    // accessCodes koleksiyonu:
    // - Sadece giriş yapmış kullanıcılar okuyabilir
    // - Yazma: Seed sırasında geçici izin, sonra false
    match /accessCodes/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
